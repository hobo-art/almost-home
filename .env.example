# Database (PostgreSQL)
# For local dev: postgresql://user:password@localhost:5432/almosthome
# For production: Use Neon, Supabase, or Railway PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/almosthome"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Email (for magic link auth + purchase confirmations)
# Using Resend: https://resend.com
EMAIL_SERVER_HOST="smtp.resend.com"
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER="resend"
EMAIL_SERVER_PASSWORD="re_your_resend_api_key"
EMAIL_FROM="Almost Home <noreply@almost-home.io>"
# Optional: for purchase confirmation emails (defaults to EMAIL_SERVER_PASSWORD if unset)
RESEND_API_KEY="re_your_resend_api_key"

# Anthropic (Claude API for narrative generation)
ANTHROPIC_API_KEY="sk-ant-your-key-here"

# Stripe (payments)
STRIPE_SECRET_KEY="sk_test_your-key-here"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your-key-here"
